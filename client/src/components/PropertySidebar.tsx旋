import { useState } from "react";
import { Link } from "wouter";
import { zones } from "@/lib/properties";
import { Input } from "@/components/ui/input";
import { Search, ChevronDown, ChevronRight } from "lucide-react";

interface PropertySidebarProps {
  activeZone?: string | null;
}

export default function PropertySidebar({ activeZone }: PropertySidebarProps) {
  const [search, setSearch] = useState("");

  const mainGroups = [
    {
      id: "madrid-capital",
      title: "MADRID (CAPITAL)",
      subItems: zones.filter(z => z.parent === "madrid-capital")
    },
    {
      id: "areas-residenciales",
      title: "MADRID - ÁREAS RESIDENCIALES",
      subItems: zones.filter(z => z.parent === "areas-residenciales")
    }
  ];

  const independentZones = zones.filter(z => !z.parent && !z.featured && z.id !== "singulares");

  return (
    <aside className="w-full lg:w-[320px] bg-white border border-gray-100 p-8 shadow-sm h-fit sticky top-24">
      <div className="space-y-12">
        {/* Search */}
        <div className="space-y-4">
          <h3 className="text-xs tracking-[0.2em] font-semibold text-[#2C2C2C] uppercase" style={{ fontFamily: 'var(--font-heading)' }}>
            BUSCER PROPIEDADES
          </h3>
          <div className="relative group">
            <Input 
              placeholder="Buscar zona o barrio..." 
              className="pl-4 pr-10 py-5 border-gray-200 rounded-none focus:ring-[#B8A07E] focus:border-[#B8A07E] bg-white transition-all text-sm"
              value={search}
              onChange={(e) => setSearch(e.target.value)}
            />
            <Search className="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 group-hover:text-[#B8A07E] transition-colors w-4 h-4" />
          </div>
        </div>

        {/* Categories / Zones */}
        <div className="space-y-6">
          {mainGroups.map(group => (
            <div key={group.id} className="border-b border-gray-50 pb-4 last:border-0 md:last:border-b">
              <details open className="group">
                <summary className="flex items-center justify-between cursor-pointer list-none text-[11px] tracking-widest font-bold text-gray-800 hover:text-[#B8A07E] transition-all py-2">
                  <div className="flex items-center gap-2">
                    <ChevronDown className="w-3 h-3 text-[#B8A07E] transition-transform group-open:rotate-180" />
                    <span>{group.title}</span>
                  </div>
                </summary>
                <div className="mt-4 space-y-1 pl-5 border-l border-gray-50 ml-1.5">
                   <Link href={`/propiedades?zona=${group.id}`}>
                    <span className={`block text-[13px] py-1.5 cursor-pointer transition-colors ${activeZone === group.id ? "text-[#B8A07E] font-medium" : "text-gray-500 hover:text-gray-900"}`}>
                      Otras zonas
                    </span>
                  </Link>
                  {group.subItems.map(item => (
                    <Link key={item.id} href={`/propiedades?zona=${item.id}`}>
                      <span className={`block text-[13px] py-1.5 cursor-pointer transition-colors ${activeZone === item.id ? "text-[#B8A07E] font-medium" : "text-gray-500 hover:text-gray-900"}`}>
                        {item.name}
                      </span>
                    </Link>
                  ))}
                </div>
              </details>
            </div>
          ))}

          {/* Independent Zones */}
          {independentZones.map(zone => (
            <div key={zone.id} className="border-b border-gray-50 pb-4">
               <Link href={`/propiedades?zona=${zone.id}`}>
                <div className="flex items-center justify-between cursor-pointer text-[11px] tracking-widest font-bold text-gray-800 hover:text-[#B8A07E] transition-all py-2">
                  <span>{zone.name.toUpperCase()}</span>
                  <ChevronRight className="w-3 h-3 text-gray-300" />
                </div>
              </Link>
            </div>
          ))}
        </div>

        {/* Global Action Button */}
        <Link href="/propiedades?zona=singulares">
          <button className={`w-full py-4 text-[10px] tracking-[0.3em] uppercase transition-all duration-300 font-bold shadow-sm ${activeZone === 'singulares' ? 'bg-[#B8A07E] text-white' : 'bg-[#2C2C2C] text-[#B8A07E] hover:bg-black'}`}>
            Propiedades Singulares
          </button>
        </Link>
      </div>
    </aside>
  );
}
